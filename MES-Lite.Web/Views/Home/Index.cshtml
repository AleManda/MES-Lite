@model String

@{
    ViewData["Title"] = "Home Page";
}

<h1 class="display-4">@Model</h1>

@if (!string.IsNullOrEmpty(Model))
{
    <p>Your role: <strong>@Model</strong></p>

    @if (Model.ToLower() == "admin" || Model.ToLower() == "qa" || Model.ToLower() == "operatore" || Model.ToLower() == "supervisor")
    {
        <div class="text-left">
            <h1 class="display-4">Welcome</h1>
            <p>Material Definitions <a href="https://localhost:5001/MaterialDefinitions/?pageIndex=1">Material Definitions</a>.</p>
            <p>Material Lots <a href="https://localhost:5001/MaterialLots/?pageIndex=1">Material Lots</a>.</p>
            <p>Material Requirements <a href="https://localhost:5001/MaterialRequirements/?pageIndex=1">Material Requirements</a>.</p>
            <p>Work Orders <a href="https://localhost:5001/WorkOrders/?pageIndex=1">Work Orders</a>.</p>
            <p>Equipments <a href="https://localhost:5001/Equipments/?pageIndex=1">Equipments</a>.</p>
            <p>Personnels <a href="https://localhost:5001/Personnels/?pageIndex=1">Personnels</a>.</p>


        </div>
        
    }
}
else
{
    <p>You are not signed in.</p>
}



